        "CONTEXT7_API_KEY": "ctx7sk-f40c5d03-49d1-428f-bdb4-d2f8d9c4ad3d"
      },
      "enabled": true
    }
  },
  "plugin": [
    "./plugin/idle-notify.ts"
  ]
