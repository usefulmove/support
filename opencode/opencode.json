{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-6",
  "small_model": "anthropic/claude-haiku-4-5",
  "mcp": {
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "permission": {
    "read": "allow",
    "list": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "lsp": "allow",
    "skill": "allow",
    "task": "allow",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "ls": "allow",
      "ls *": "allow",
      "cat": "allow",
      "cat *": "allow",
      "find": "allow",
      "find *": "allow",
      "fd": "allow",
      "fd *": "allow",
      "grep": "allow",
      "grep *": "allow",
      "rg": "allow",
      "rg *": "allow",
      "which": "allow",
      "which *": "allow",
      "wc": "allow",
      "wc *": "allow",
      "head": "allow",
      "head *": "allow",
      "tail": "allow",
      "tail *": "allow",
      "stat": "allow",
      "stat *": "allow",
      "tree": "allow",
      "tree *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git rev-parse": "allow",
      "git rev-parse *": "allow"
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "bash": {
          "*": "ask",
          "pwd": "allow",
          "ls": "allow",
          "ls *": "allow",
          "cat": "allow",
          "cat *": "allow",
          "find": "allow",
          "find *": "allow",
          "fd": "allow",
          "fd *": "allow",
          "grep": "allow",
          "grep *": "allow",
          "rg": "allow",
          "rg *": "allow",
          "which": "allow",
          "which *": "allow",
          "wc": "allow",
          "wc *": "allow",
          "head": "allow",
          "head *": "allow",
          "tail": "allow",
          "tail *": "allow",
          "stat": "allow",
          "stat *": "allow",
          "tree": "allow",
          "tree *": "allow",
          "git status": "allow",
          "git status *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git show": "allow",
          "git show *": "allow",
          "git ls-files": "allow",
          "git ls-files *": "allow",
          "git rev-parse": "allow",
          "git rev-parse *": "allow"
        }
      }
    }
  },
  "plugin": [
    "./plugin/idle-notify.ts"
  ],
  "provider": {
    "anthropic": {
      "options": {
        "setCacheKey": true
      }
    },
    "ollama": {
      "models": {
        "glm-5:cloud": {
          "name": "glm-5:cloud"
        },
        "kimi-k2.5:cloud": {
          "name": "kimi-k2.5:cloud"
        },
        "qwen3-coder-next": {
          "name": "qwen3-coder-next"
        },
        "qwen3-coder-next:cloud": {
          "name": "qwen3-coder-next:cloud"
        }
      },
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  }
}
