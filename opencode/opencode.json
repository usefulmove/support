{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/kimi-k2.5",
  "mcp": {
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "permission": {
    "read": "allow",
    "list": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "lsp": "allow",
    "skill": "allow",
    "task": "allow",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "ls": "allow",
      "ls *": "allow",
      "cat": "allow",
      "cat *": "allow",
      "find": "allow",
      "find *": "allow",
      "fd": "allow",
      "fd *": "allow",
      "grep": "allow",
      "grep *": "allow",
      "rg": "allow",
      "rg *": "allow",
      "which": "allow",
      "which *": "allow",
      "wc": "allow",
      "wc *": "allow",
      "head": "allow",
      "head *": "allow",
      "tail": "allow",
      "tail *": "allow",
      "stat": "allow",
      "stat *": "allow",
      "tree": "allow",
      "tree *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git rev-parse": "allow",
      "git rev-parse *": "allow"
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "bash": {
          "*": "ask",
          "pwd": "allow",
          "ls": "allow",
          "ls *": "allow",
          "cat": "allow",
          "cat *": "allow",
          "find": "allow",
          "find *": "allow",
          "fd": "allow",
          "fd *": "allow",
          "grep": "allow",
          "grep *": "allow",
          "rg": "allow",
          "rg *": "allow",
          "which": "allow",
          "which *": "allow",
          "wc": "allow",
          "wc *": "allow",
          "head": "allow",
          "head *": "allow",
          "tail": "allow",
          "tail *": "allow",
          "stat": "allow",
          "stat *": "allow",
          "tree": "allow",
          "tree *": "allow",
          "git status": "allow",
          "git status *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git show": "allow",
          "git show *": "allow",
          "git ls-files": "allow",
          "git ls-files *": "allow",
          "git rev-parse": "allow",
          "git rev-parse *": "allow"
        }
      }
    }
  },
  "mode": {
    "reasoner": {
      "model": "anthropic/claude-sonnet-4-6",
      "temperature": 0.2,
      "prompt": "{file:~/.config/opencode/prompts/reasoner.md}",
      "permission": {
        "bash": {
          "*": "ask",
          "pwd": "allow",
          "ls": "allow",
          "ls *": "allow",
          "cat": "allow",
          "cat *": "allow",
          "find": "allow",
          "find *": "allow",
          "fd": "allow",
          "fd *": "allow",
          "grep": "allow",
          "grep *": "allow",
          "rg": "allow",
          "rg *": "allow",
          "which": "allow",
          "which *": "allow",
          "wc": "allow",
          "wc *": "allow",
          "head": "allow",
          "head *": "allow",
          "tail": "allow",
          "tail *": "allow",
          "stat": "allow",
          "stat *": "allow",
          "tree": "allow",
          "tree *": "allow",
          "git status": "allow",
          "git status *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git show": "allow",
          "git show *": "allow",
          "git ls-files": "allow",
          "git ls-files *": "allow",
          "git rev-parse": "allow",
          "git rev-parse *": "allow"
        }
      },
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "lsp": true,
        "websearch": true,
        "codesearch": true,
        "task": true,
        "skill": true,
        "list": true,
        "write": false,
        "edit": false,
        "bash": true
      }
    },
    "researcher": {
      "model": "opencode/gemini-3.1-pro",
      "temperature": 0.3,
      "prompt": "{file:~/.config/opencode/prompts/researcher.md}",
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "lsp": true,
        "websearch": true,
        "webfetch": true,
        "codesearch": true,
        "task": true,
        "skill": true,
        "list": true
      }
    },
    "QA": {
      "model": "anthropic/claude-sonnet-4-6",
      "temperature": 0.1,
      "prompt": "{file:~/.config/opencode/prompts/qa.md}",
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "lsp": true,
        "websearch": true,
        "codesearch": true,
        "task": true,
        "skill": true,
        "list": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "teacher": {
      "model": "anthropic/claude-sonnet-4-6",
      "temperature": 0.3,
      "prompt": "{file:~/.config/opencode/prompts/teacher.md}",
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "lsp": true,
        "websearch": true,
        "webfetch": true,
        "codesearch": true,
        "task": true,
        "skill": true,
        "list": true,
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "narrator": {
      "model": "opencode/kimi-k2.5",
      "temperature": 0.4,
      "prompt": "{file:~/.config/opencode/prompts/narrator.md}",
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "lsp": true,
        "websearch": true,
        "codesearch": true,
        "task": true,
        "skill": true,
        "list": true,
        "write": true,
        "edit": true
      }
    },
    "creator": {
      "model": "anthropic/claude-opus-4-6",
      "temperature": 0.7,
      "prompt": "{file:~/.config/opencode/prompts/creator.md}",
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "lsp": true,
        "websearch": true,
        "codesearch": true,
        "task": true,
        "skill": true,
        "list": true,
        "write": true,
        "edit": true
      }
    },
    "coder": {
      "model": "opencode/gpt-5.4",
      "temperature": 0.1,
      "prompt": "{file:~/.config/opencode/prompts/coder.md}",
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "lsp": true,
        "websearch": true,
        "webfetch": true,
        "codesearch": true,
        "task": true,
        "skill": true,
        "list": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "multi-modal": {
      "model": "opencode/gemini-3.1-pro",
      "temperature": 0.3,
      "prompt": "{file:~/.config/opencode/prompts/multi-modal.md}",
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "lsp": true,
        "websearch": true,
        "webfetch": true,
        "codesearch": true,
        "task": true,
        "skill": true,
        "list": true,
        "write": true,
        "edit": true
      }
    }
  },
  "plugin": [
    "./plugin/idle-notify.ts"
  ],
  "provider": {
    "anthropic": {
      "options": {
        "setCacheKey": true
      }
    },
    "ollama": {
      "models": {
        "glm-5.1:cloud": {
          "name": "glm-5.1:cloud"
        },
        "kimi-k2.5:cloud": {
          "name": "kimi-k2.5:cloud"
        },
        "minimax-m2.7:cloud": {
          "name": "minimax-m2.7:cloud"
        },
        "gemma4:31b-cloud": {
          "name": "gemma4:31b-cloud"
        },
        "qwen3-coder-next:cloud": {
          "name": "qwen3-coder-next:cloud"
        }
      },
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  }
}
